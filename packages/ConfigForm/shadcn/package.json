{
  "name": "@moluoxixi/config-form-shadcn-vue",
  "type": "module",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/moluoxixi/vue-components",
    "directory": "packages/ConfigForm/shadcn"
  },
  "sideEffects": [
    "**/*.scss",
    "**/*.css"
  ],
  "exports": {
    ".": {
      "source": "./index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles": {
      "sass": "./src/styles.scss",
      "style": "./src/styles.scss",
      "default": "./src/styles.scss"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src/styles.scss"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "typecheck": "vue-tsc -p tsconfig.app.json --noEmit"
  },
  "peerDependencies": {
    "@moluoxixi/config-form-core": "^0.1.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@moluoxixi/config-form-core": "workspace:*",
    "@vitejs/plugin-vue": "catalog:dev",
    "@vue/test-utils": "catalog:dev",
    "happy-dom": "catalog:dev",
    "sass": "catalog:dev",
    "unplugin-dts": "catalog:dev",
    "vite": "catalog:dev",
    "vitest": "catalog:dev",
    "vue": "catalog:build",
    "vue-tsc": "catalog:dev"
  },
  "publishConfig": {
    "access": "public"
  }
}
