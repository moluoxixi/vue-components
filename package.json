{
  "name": "components",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.29.3"
  },
  "scripts": {
    "changeset": "changeset",
    "dev:ep": "pnpm build && pnpm -C playgrounds/element-plus-playground dev",
    "dev:antd": "pnpm build && pnpm -C playgrounds/antd-vue-playground dev",
    "dev:components": "pnpm build && pnpm -C playgrounds/components-playground dev",
    "dev:shadcn": "pnpm -C packages/ConfigForm build && pnpm -C playgrounds/shadcn-vue-playground dev",
    "build": "pnpm -r --filter \"./packages/*\" --filter \"./playgrounds/*\" build",
    "lint": "node scripts/check-element-plus-imports.mjs && eslint .",
    "lint:fix": "eslint . --fix",
    "lint:staged": "lint-staged",
    "prepare": "husky",
    "pre-commit": "pnpm lint:staged && pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "release": "pnpm build && changeset publish",
    "test": "pnpm -C packages/ConfigForm build && pnpm -r --filter \"./packages/*\" test",
    "test:coverage": "pnpm -C packages/ConfigForm build && pnpm -r --filter \"./packages/*\" test:coverage",
    "test:e2e:playground": "pnpm build && pnpm -C playgrounds/element-plus-playground test:e2e && pnpm -C playgrounds/antd-vue-playground test:e2e",
    "test:e2e:playground:headed": "pnpm build && pnpm -C playgrounds/element-plus-playground test:e2e:headed && pnpm -C playgrounds/antd-vue-playground test:e2e:headed",
    "typecheck": "pnpm -r --filter \"./packages/*\" build && pnpm -r --filter \"./packages/*\" --filter \"./playgrounds/*\" typecheck",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:dev",
    "@changesets/cli": "catalog:dev",
    "@playwright/test": "catalog:dev",
    "@types/node": "catalog:type",
    "eslint": "catalog:dev",
    "eslint-plugin-format": "catalog:dev",
    "husky": "catalog:dev",
    "jiti": "catalog:dev",
    "lint-staged": "catalog:dev",
    "typescript": "catalog:dev",
    "vitest": "catalog:dev"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,tsx,vue}": "pnpm lint"
  }
}
