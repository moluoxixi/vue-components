{
  "name": "@moluoxixi/config-form",
  "type": "module",
  "version": "0.1.1",
  "sideEffects": [
    "**/*.scss",
    "**/*.css"
  ],
  "exports": {
    ".": {
      "source": "./index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugins": {
      "source": "./src/plugins/index.ts",
      "types": "./dist/src/plugins/index.d.ts",
      "import": "./dist/plugins.js"
    },
    "./styles": {
      "sass": "./src/styles/index.scss",
      "style": "./src/styles/index.scss",
      "default": "./src/styles/index.scss"
    },
    "./styles/*": {
      "sass": "./src/styles/*",
      "style": "./src/styles/*",
      "default": "./src/styles/*"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src/styles",
    "styles"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "vue-tsc -p tsconfig.test.json --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "catalog:dev",
    "@vitest/coverage-v8": "catalog:dev",
    "@vue/language-core": "catalog:dev",
    "@vue/test-utils": "catalog:dev",
    "happy-dom": "catalog:dev",
    "sass": "catalog:dev",
    "unplugin-dts": "catalog:dev",
    "vite": "catalog:dev",
    "vitest": "catalog:dev",
    "vue": "catalog:build",
    "vue-tsc": "catalog:dev",
    "zod": "catalog:dev"
  },
  "publishConfig": {
    "access": "public"
  }
}
