{
  "name": "@moluoxixi/config-form-plugin-antd-vue",
  "type": "module",
  "version": "0.1.0",
  "sideEffects": false,
  "exports": {
    ".": {
      "source": "./index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "vue-tsc -p tsconfig.test.json --noEmit"
  },
  "peerDependencies": {
    "@moluoxixi/config-form": "^0.1.1",
    "ant-design-vue": "^4.2.0"
  },
  "devDependencies": {
    "@moluoxixi/config-form": "workspace:*",
    "@vitest/coverage-v8": "catalog:dev",
    "@vue/test-utils": "catalog:dev",
    "ant-design-vue": "catalog:ui",
    "unplugin-dts": "catalog:dev",
    "vite": "catalog:dev",
    "vitest": "catalog:dev",
    "vue": "catalog:build",
    "vue-tsc": "catalog:dev"
  },
  "publishConfig": {
    "access": "public"
  }
}
