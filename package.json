{
  "name": "components",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.29.3"
  },
  "scripts": {
    "changeset": "changeset",
    "dev:components": "pnpm build && pnpm -C playgrounds/components-playground dev",
    "dev:config-form": "pnpm build && pnpm -C packages/ConfigForm/playground dev",
    "build": "pnpm -r --filter \"./packages/**\" --filter \"!./packages/ConfigForm/playground\" build",
    "build:playgrounds": "pnpm -r --filter \"./packages/ConfigForm/playground\" --filter \"./playgrounds/*\" build",
    "lint": "node scripts/check-element-plus-imports.mjs && eslint .",
    "lint:fix": "eslint . --fix",
    "lint:staged": "lint-staged",
    "prepare": "husky",
    "pre-commit": "node scripts/check-element-plus-imports.mjs && pnpm lint:staged",
    "release": "pnpm build && changeset publish",
    "test": "pnpm -C packages/ConfigForm/runtime build && pnpm -r --filter \"./packages/**\" test",
    "test:coverage": "pnpm -C packages/ConfigForm/runtime build && pnpm -r --filter \"./packages/**\" test:coverage",
    "test:e2e:config-form": "pnpm build && pnpm -C packages/ConfigForm/playground test:e2e",
    "typecheck": "pnpm -r --filter \"./packages/**\" build && pnpm -r --filter \"./packages/**\" --filter \"./playgrounds/*\" typecheck",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:dev",
    "@changesets/cli": "catalog:dev",
    "@playwright/test": "catalog:dev",
    "@types/node": "catalog:type",
    "eslint": "catalog:dev",
    "eslint-plugin-format": "catalog:dev",
    "husky": "catalog:dev",
    "jiti": "catalog:dev",
    "lint-staged": "catalog:dev",
    "typescript": "catalog:dev",
    "vitest": "catalog:dev"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,tsx,vue}": "eslint --fix"
  }
}
