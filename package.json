{
  "name": "components",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.29.3"
  },
  "scripts": {
    "changeset": "changeset",
    "dev:ep": "pnpm build && pnpm -C playgrounds/element-plus-playground dev",
    "dev:antd": "pnpm build && pnpm -C playgrounds/antd-vue-playground dev",
    "build": "pnpm -r --filter \"./packages/*\" --filter \"./playgrounds/*\" build",
    "lint": "node scripts/check-element-plus-imports.mjs && eslint .",
    "lint:fix": "eslint . --fix",
    "release": "pnpm build && changeset publish",
    "test": "pnpm -C packages/ConfigForm build && pnpm -r --filter \"./packages/*\" test",
    "test:coverage": "pnpm -C packages/ConfigForm build && pnpm -r --filter \"./packages/*\" test:coverage",
    "typecheck": "pnpm -r --filter \"./packages/*\" build && pnpm -r --filter \"./packages/*\" --filter \"./playgrounds/*\" typecheck",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:dev",
    "@changesets/cli": "catalog:dev",
    "@types/node": "catalog:type",
    "eslint": "catalog:dev",
    "eslint-plugin-format": "catalog:dev",
    "jiti": "catalog:dev",
    "typescript": "catalog:dev",
    "vitest": "catalog:dev"
  }
}
