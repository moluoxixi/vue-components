{
  "name": "@moluoxixi/config-form-devtools-vite-plugin",
  "type": "module",
  "version": "0.2.0",
  "sideEffects": false,
  "exports": {
    ".": {
      "source": "./index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "vue-tsc -p tsconfig.test.json --noEmit"
  },
  "peerDependencies": {
    "@moluoxixi/config-form": "^0.1.1",
    "vite": "^6.2.0",
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@babel/parser": "catalog:dev",
    "@vue/compiler-sfc": "catalog:dev",
    "launch-editor": "catalog:dev",
    "magic-string": "catalog:dev"
  },
  "devDependencies": {
    "@moluoxixi/config-form": "workspace:*",
    "@types/node": "catalog:type",
    "@vitest/coverage-v8": "catalog:dev",
    "happy-dom": "catalog:dev",
    "typescript": "catalog:dev",
    "unplugin-dts": "catalog:dev",
    "vite": "catalog:dev",
    "vitest": "catalog:dev",
    "vue": "catalog:build",
    "vue-tsc": "catalog:dev"
  },
  "publishConfig": {
    "access": "public"
  }
}
