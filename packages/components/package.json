{
  "name": "@moluoxixi/components",
  "type": "module",
  "version": "0.1.0",
  "sideEffects": [
    "**/*.scss",
    "**/*.css"
  ],
  "exports": {
    ".": {
      "source": "./index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles": {
      "import": "./dist/components.css"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "typecheck": "vue-tsc -p tsconfig.app.json --noEmit"
  },
  "peerDependencies": {
    "ant-design-vue": "^4.2.0",
    "element-plus": "^2.9.0",
    "vue": "^3.5.0"
  },
  "dependencies": {
    "dayjs": "catalog:build"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "catalog:dev",
    "@vue/test-utils": "catalog:dev",
    "ant-design-vue": "catalog:ui",
    "element-plus": "catalog:ui",
    "happy-dom": "catalog:dev",
    "unplugin-dts": "catalog:dev",
    "vite": "catalog:dev",
    "vitest": "catalog:dev",
    "vue": "catalog:build",
    "vue-tsc": "catalog:dev"
  },
  "publishConfig": {
    "access": "public"
  }
}
