{
  "name": "@moluoxixi/hooks",
  "type": "module",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/moluoxixi/vue-components",
    "directory": "packages/hooks"
  },
  "exports": {
    ".": {
      "source": "./index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "vue-tsc -p tsconfig.app.json --noEmit"
  },
  "peerDependencies": {
    "@tanstack/vue-query": "^5.0.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@tanstack/vue-query": "catalog:data",
    "@vitejs/plugin-vue": "catalog:dev",
    "@vitest/coverage-v8": "catalog:dev",
    "@vue/test-utils": "catalog:dev",
    "happy-dom": "catalog:dev",
    "unplugin-dts": "catalog:dev",
    "vite": "catalog:dev",
    "vitest": "catalog:dev",
    "vue": "catalog:build",
    "vue-tsc": "catalog:dev"
  },
  "publishConfig": {
    "access": "public"
  }
}
